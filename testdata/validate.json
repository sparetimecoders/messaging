          ]
        },
        {
          "serviceName": "notifications",
          "endpoints": [
            {
              "direction": "consume",
              "pattern": "event-stream",
              "exchangeName": "events.topic.exchange",
              "exchangeKind": "topic",
              "queueName": "events.topic.exchange.queue.notifications",
              "routingKey": "Order.Created"
            }
          ]
        },
        {
          "serviceName": "analytics",
          "endpoints": [
            {
              "direction": "consume",
