{
  "scenarios": [
    {
      "name": "event stream publish and consume",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "expectedEndpoints": {
        "amqp": {
          "orders": [
            {"direction":"publish","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic"}
          ],
          "notifications": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic","queueName":"events.topic.exchange.queue.notifications","routingKey":"Order.Created"}
          ]
        },
        "nats": {
          "orders": [
            {"direction":"publish","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic"}
          ],
          "notifications": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic","queueName":"notifications","routingKey":"Order.Created"}
          ]
        }
      },
      "broker": {
        "amqp": {
          "exchanges": [
            {"name":"events.topic.exchange","type":"topic","durable":true,"autoDelete":false}
          ],
          "queues": [
            {"name":"events.topic.exchange.queue.notifications","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":432000000}}
          ],
          "bindings": [
            {"source":"events.topic.exchange","destination":"events.topic.exchange.queue.notifications","routingKey":"Order.Created"}
          ]
        },
        "nats": {
          "streams": [
            {"name":"events","subjects":["events.\u003e"],"storage":"file"}
          ],
          "consumers": [
            {"stream":"events","durable":"notifications","filterSubject":"events.Order.Created","ackPolicy":"explicit"}
          ]
        }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-123","amount":42},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-123","amount":42}}
          ]
        }
      ]
    },
    {
      "name": "event stream fan-out",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] },
        "analytics":     { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "expectedEndpoints": {
        "amqp": {
          "orders": [
            {"direction":"publish","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic"}
          ],
          "notifications": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic","queueName":"events.topic.exchange.queue.notifications","routingKey":"Order.Created"}
          ],
          "analytics": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic","queueName":"events.topic.exchange.queue.analytics","routingKey":"Order.Created"}
          ]
        },
        "nats": {
          "orders": [
            {"direction":"publish","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic"}
          ],
          "notifications": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic","queueName":"notifications","routingKey":"Order.Created"}
          ],
          "analytics": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic","queueName":"analytics","routingKey":"Order.Created"}
          ]
        }
      },
      "broker": {
        "amqp": {
          "exchanges": [
            {"name":"events.topic.exchange","type":"topic","durable":true,"autoDelete":false}
          ],
          "queues": [
            {"name":"events.topic.exchange.queue.notifications","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":432000000}},
            {"name":"events.topic.exchange.queue.analytics","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":432000000}}
          ],
          "bindings": [
            {"source":"events.topic.exchange","destination":"events.topic.exchange.queue.notifications","routingKey":"Order.Created"},
            {"source":"events.topic.exchange","destination":"events.topic.exchange.queue.analytics","routingKey":"Order.Created"}
          ]
        },
        "nats": {
          "streams": [
            {"name":"events","subjects":["events.\u003e"],"storage":"file"}
          ],
          "consumers": [
            {"stream":"events","durable":"notifications","filterSubject":"events.Order.Created","ackPolicy":"explicit"},
            {"stream":"events","durable":"analytics","filterSubject":"events.Order.Created","ackPolicy":"explicit"}
          ]
        }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-456","amount":99},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-456"}},
            {"to":"analytics","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"amount":99}}
          ]
        }
      ]
    },
    {
      "name": "custom stream publish and consume",
      "services": {
        "analytics": { "setups": [
          {"pattern":"custom-stream","direction":"publish","exchange":"audit"},
          {"pattern":"custom-stream","direction":"consume","exchange":"audit","routingKey":"Audit.Entry"}
        ]}
      },
      "expectedEndpoints": {
        "amqp": {
          "analytics": [
            {"direction":"publish","pattern":"custom-stream","exchangeName":"audit.topic.exchange","exchangeKind":"topic"},
            {"direction":"consume","pattern":"custom-stream","exchangeName":"audit.topic.exchange","exchangeKind":"topic","queueName":"audit.topic.exchange.queue.analytics","routingKey":"Audit.Entry"}
          ]
        },
        "nats": {
          "analytics": [
            {"direction":"publish","pattern":"custom-stream","exchangeName":"audit","exchangeKind":"topic"},
            {"direction":"consume","pattern":"custom-stream","exchangeName":"audit","exchangeKind":"topic","queueName":"analytics","routingKey":"Audit.Entry"}
          ]
        }
      },
      "broker": {
        "amqp": {
          "exchanges": [
            {"name":"audit.topic.exchange","type":"topic","durable":true,"autoDelete":false}
          ],
          "queues": [
            {"name":"audit.topic.exchange.queue.analytics","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":432000000}}
          ],
          "bindings": [
            {"source":"audit.topic.exchange","destination":"audit.topic.exchange.queue.analytics","routingKey":"Audit.Entry"}
          ]
        },
        "nats": {
          "streams": [
            {"name":"audit","subjects":["audit.\u003e"],"storage":"file"}
          ],
          "consumers": [
            {"stream":"audit","durable":"analytics","filterSubject":"audit.Audit.Entry","ackPolicy":"explicit"}
          ]
        }
      },
      "messages": [
        {
          "from": "analytics",
          "routingKey": "Audit.Entry",
          "payload": {"action":"login","userId":"user-456"},
          "expectedDeliveries": [
            {"to":"analytics","metadata":{"type":"Audit.Entry","source":"analytics","specVersion":"1.0"},"payloadMatch":{"action":"login","userId":"user-456"}}
          ]
        }
      ]
    },
    {
      "name": "transient consumer",
      "services": {
        "orders":    { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "dashboard": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created","ephemeral":true}] }
      },
      "expectedEndpoints": {
        "amqp": {
          "orders": [
            {"direction":"publish","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic"}
          ],
          "dashboard": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events.topic.exchange","exchangeKind":"topic","queueNamePrefix":"events.topic.exchange.queue.dashboard-","routingKey":"Order.Created","ephemeral":true}
          ]
        },
        "nats": {
          "orders": [
            {"direction":"publish","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic"}
          ],
          "dashboard": [
            {"direction":"consume","pattern":"event-stream","exchangeName":"events","exchangeKind":"topic","routingKey":"Order.Created","ephemeral":true}
          ]
        }
      },
      "broker": {
        "amqp": {
          "exchanges": [
            {"name":"events.topic.exchange","type":"topic","durable":true,"autoDelete":false}
          ],
          "queues": [
            {"namePrefix":"events.topic.exchange.queue.dashboard-","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":1000}}
          ],
          "bindings": [
            {"source":"events.topic.exchange","destinationPrefix":"events.topic.exchange.queue.dashboard-","routingKey":"Order.Created"}
          ]
        },
        "nats": {
          "streams": [
            {"name":"events","subjects":["events.\u003e"],"storage":"file"}
          ],
          "consumers": [
            {"stream":"events","filterSubject":"events.Order.Created","ackPolicy":"explicit"}
          ]
        }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-789","amount":10},
          "expectedDeliveries": [
            {"to":"dashboard","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-789"}}
          ]
        }
      ]
    },
    {
      "name": "service request topology",
      "services": {
        "email-svc": { "setups": [
          {"pattern":"service-request","direction":"consume","routingKey":"email.send"}
        ]},
        "web-app": { "setups": [
          {"pattern":"service-request","direction":"publish","targetService":"email-svc"},
          {"pattern":"service-response","direction":"consume","targetService":"email-svc","routingKey":"email.send"}
        ]}
      },
      "expectedEndpoints": {
        "amqp": {
          "email-svc": [
            {"direction":"consume","pattern":"service-request","exchangeName":"email-svc.direct.exchange.request","exchangeKind":"direct","queueName":"email-svc.direct.exchange.request.queue","routingKey":"email.send"}
          ],
          "web-app": [
            {"direction":"publish","pattern":"service-request","exchangeName":"email-svc.direct.exchange.request","exchangeKind":"direct"},
            {"direction":"consume","pattern":"service-response","exchangeName":"email-svc.headers.exchange.response","exchangeKind":"headers","queueName":"email-svc.headers.exchange.response.queue.web-app","routingKey":"email.send"}
          ]
        },
        "nats": {
          "email-svc": [
            {"direction":"consume","pattern":"service-request","exchangeName":"email-svc","exchangeKind":"direct","queueName":"email-svc","routingKey":"email.send"}
          ],
          "web-app": [
            {"direction":"publish","pattern":"service-request","exchangeName":"email-svc","exchangeKind":"direct"},
            {"direction":"consume","pattern":"service-response","exchangeName":"email-svc","exchangeKind":"headers","queueName":"web-app","routingKey":"email.send"}
          ]
        }
      },
      "broker": {
        "amqp": {
          "exchanges": [
            {"name":"email-svc.direct.exchange.request","type":"direct","durable":true,"autoDelete":false},
            {"name":"email-svc.headers.exchange.response","type":"headers","durable":true,"autoDelete":false}
          ],
          "queues": [
            {"name":"email-svc.direct.exchange.request.queue","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":432000000}},
            {"name":"email-svc.headers.exchange.response.queue.web-app","durable":true,"autoDelete":false,"arguments":{"x-queue-type":"quorum","x-expires":432000000}}
          ],
          "bindings": [
            {"source":"email-svc.direct.exchange.request","destination":"email-svc.direct.exchange.request.queue","routingKey":"email.send"},
            {"source":"email-svc.headers.exchange.response","destination":"email-svc.headers.exchange.response.queue.web-app","routingKey":"email.send"}
          ]
        },
        "nats": {
          "streams": [],
          "consumers": []
        }
      },
      "messages": []
    }
  ]
}
