              "exchangeKind": "topic",
              "queueName": "nats-consumer",
              "routingKey": "Order.Created"
            }
          ]
        }
      ],
      "expectedError": "no service publishes it"
    },
    {
      "name": "multiple publishers multiple consumers",
      "topologies": [
        {
          "serviceName": "orders",
          "endpoints": [
            {
              "direction": "publish",
              "pattern": "event-stream",
              "exchangeName": "events.topic.exchange",
              "exchangeKind": "topic",
              "routingKey": "Order.Created"
            },
            {
              "direction": "publish",
              "pattern": "event-stream",
