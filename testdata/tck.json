{
  "scenarios": [
    {
      "name": "event stream publish and consume",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-123","amount":42},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-123","amount":42}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.Outbound",
          "payload": {"probeId":"out-1"},
          "ceAttributes": {"type":"Probe.Outbound","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "notifications",
          "routingKey": "Order.Created",
          "payload": {"probeId":"in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "event stream fan-out",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] },
        "analytics":     { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-456","amount":99},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-456"}},
            {"to":"analytics","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"amount":99}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.FanOut",
          "payload": {"probeId":"fanout-out-1"},
          "ceAttributes": {"type":"Probe.FanOut","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"fanout-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "notifications",
          "routingKey": "Order.Created",
          "payload": {"probeId":"fanout-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"fanout-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "custom stream publish and consume",
      "services": {
        "analytics": { "setups": [
          {"pattern":"custom-stream","direction":"publish","exchange":"audit"},
          {"pattern":"custom-stream","direction":"consume","exchange":"audit","routingKey":"Audit.Entry"}
        ]}
      },
      "messages": [
        {
          "from": "analytics",
          "routingKey": "Audit.Entry",
          "payload": {"action":"login","userId":"user-456"},
          "expectedDeliveries": [
            {"to":"analytics","metadata":{"type":"Audit.Entry","source":"analytics","specVersion":"1.0"},"payloadMatch":{"action":"login","userId":"user-456"}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "analytics",
          "routingKey": "Probe.AuditOut",
          "payload": {"probeId":"audit-out-1"},
          "ceAttributes": {"type":"Probe.AuditOut","source":"analytics","specversion":"1.0"},
          "payloadMatch": {"probeId":"audit-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "analytics",
          "routingKey": "Audit.Entry",
          "payload": {"probeId":"audit-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Audit.Entry","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"audit-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "transient consumer",
      "services": {
        "orders":    { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "dashboard": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created","ephemeral":true}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-789","amount":10},
          "expectedDeliveries": [
            {"to":"dashboard","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-789"}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.Transient",
          "payload": {"probeId":"transient-out-1"},
          "ceAttributes": {"type":"Probe.Transient","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"transient-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "dashboard",
          "routingKey": "Order.Created",
          "payload": {"probeId":"transient-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"transient-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "service request topology",
      "services": {
        "email-svc": { "setups": [
          {"pattern":"service-request","direction":"consume","routingKey":"email.send"}
        ]},
        "web-app": { "setups": [
          {"pattern":"service-request","direction":"publish","targetService":"email-svc"},
          {"pattern":"service-response","direction":"consume","targetService":"email-svc","routingKey":"email.send"}
        ]}
      },
      "messages": [
        {
          "from": "web-app",
          "routingKey": "email.send",
          "payload": {"to":"user@example.com","subject":"Welcome","body":"Hello!"},
          "expectedDeliveries": [
            {"to":"email-svc","metadata":{"type":"email.send","source":"web-app","specVersion":"1.0"},"payloadMatch":{"to":"user@example.com","subject":"Welcome"}}
          ]
        }
      ]
    },
    {
      "name": "wildcard routing",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.*"}] },
        "billing":       { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"wc-1","amount":50},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"wc-1"}},
            {"to":"billing","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"wc-1"}}
          ]
        },
        {
          "from": "orders",
          "routingKey": "Order.Updated",
          "payload": {"orderId":"wc-2","status":"shipped"},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Updated","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"wc-2"}}
          ],
          "unexpectedDeliveries": [
            {"to":"billing","metadataType":"Order.Updated"}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.WildcardOut",
          "payload": {"probeId":"wc-out-1"},
          "ceAttributes": {"type":"Probe.WildcardOut","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"wc-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "notifications",
          "routingKey": "Order.Created",
          "payload": {"probeId":"wc-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"wc-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "custom stream transient consumer",
      "services": {
        "metrics-pub": { "setups": [{"pattern":"custom-stream","direction":"publish","exchange":"telemetry"}] },
        "live-view":   { "setups": [{"pattern":"custom-stream","direction":"consume","exchange":"telemetry","routingKey":"Metric.Recorded","ephemeral":true}] }
      },
      "messages": [
        {
          "from": "metrics-pub",
          "routingKey": "Metric.Recorded",
          "payload": {"metricName":"cpu_usage","value":72.5},
          "expectedDeliveries": [
            {"to":"live-view","metadata":{"type":"Metric.Recorded","source":"metrics-pub","specVersion":"1.0"},"payloadMatch":{"metricName":"cpu_usage","value":72.5}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "metrics-pub",
          "routingKey": "Probe.TelemetryOut",
          "payload": {"probeId":"telemetry-out-1"},
          "ceAttributes": {"type":"Probe.TelemetryOut","source":"metrics-pub","specversion":"1.0"},
          "payloadMatch": {"probeId":"telemetry-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "live-view",
          "routingKey": "Metric.Recorded",
          "payload": {"probeId":"telemetry-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Metric.Recorded","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"telemetry-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "queue suffix multiple consumers",
      "services": {
        "orders":  { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "backend": { "setups": [
          {"pattern":"event-stream","direction":"consume","routingKey":"Order.Created","queueSuffix":"reminders"},
          {"pattern":"event-stream","direction":"consume","routingKey":"Order.Created","queueSuffix":"reporting"}
        ]}
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"suffix-1","amount":100},
          "expectedDeliveries": [
            {"to":"backend","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"suffix-1"}},
            {"to":"backend","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"suffix-1"}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.SuffixOut",
          "payload": {"probeId":"suffix-out-1"},
          "ceAttributes": {"type":"Probe.SuffixOut","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"suffix-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "backend",
          "routingKey": "Order.Created",
          "payload": {"probeId":"suffix-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"suffix-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "wildcard catch-all routing",
      "services": {
        "orders":   { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "payments": { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "readview": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"#"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"catchall-1"},
          "expectedDeliveries": [
            {"to":"readview","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"catchall-1"}}
          ]
        },
        {
          "from": "payments",
          "routingKey": "Payment.Processed",
          "payload": {"paymentId":"catchall-2"},
          "expectedDeliveries": [
            {"to":"readview","metadata":{"type":"Payment.Processed","source":"payments","specVersion":"1.0"},"payloadMatch":{"paymentId":"catchall-2"}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "inbound",
          "expectReceivedBy": "readview",
          "routingKey": "Order.Created",
          "payload": {"probeId":"catchall-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"catchall-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "service request-response round trip",
      "transports": ["amqp"],
      "services": {
        "task-svc":  { "setups": [
          {"pattern":"service-request","direction":"consume","routingKey":"task.execute"},
          {"pattern":"service-response","direction":"publish"}
        ]},
        "scheduler": { "setups": [
          {"pattern":"service-request","direction":"publish","targetService":"task-svc"},
          {"pattern":"service-response","direction":"consume","targetService":"task-svc","routingKey":"task.execute"}
        ]}
      },
      "messages": [
        {
          "from": "scheduler",
          "routingKey": "task.execute",
          "payload": {"taskId":"rt-1","action":"run"},
          "expectedDeliveries": [
            {"to":"task-svc","metadata":{"type":"task.execute","source":"scheduler","specVersion":"1.0"},"payloadMatch":{"taskId":"rt-1"}}
          ],
          "responseMessages": [
            {
              "from": "task-svc",
              "targetService": "scheduler",
              "routingKey": "task.execute",
              "payload": {"taskId":"rt-1","status":"completed"},
              "expectedDeliveries": [
                {"to":"scheduler","metadata":{"type":"task.execute","source":"task-svc","specVersion":"1.0"},"payloadMatch":{"status":"completed"}}
              ]
            }
          ]
        }
      ]
    },
    {
      "name": "custom headers propagation",
      "services": {
        "scheduler": { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "worker":    { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Task.Scheduled"}] }
      },
      "messages": [
        {
          "from": "scheduler",
          "routingKey": "Task.Scheduled",
          "payload": {"taskId":"hdr-1","priority":"high"},
          "customHeaders": {"x-delay-until":"2026-03-01T00:00:00Z","x-priority":"high"},
          "expectedDeliveries": [
            {
              "to":"worker",
              "metadata":{"type":"Task.Scheduled","source":"scheduler","specVersion":"1.0"},
              "payloadMatch":{"taskId":"hdr-1"},
              "headerMatch":{"x-delay-until":"2026-03-01T00:00:00Z","x-priority":"high"}
            }
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "scheduler",
          "routingKey": "Probe.HeaderOut",
          "payload": {"probeId":"hdr-out-1"},
          "ceAttributes": {"type":"Probe.HeaderOut","source":"scheduler","specversion":"1.0"},
          "payloadMatch": {"probeId":"hdr-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "worker",
          "routingKey": "Task.Scheduled",
          "payload": {"probeId":"hdr-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Task.Scheduled","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"hdr-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "queue publish sender-selected distribution",
      "transports": ["amqp"],
      "services": {
        "sender":   { "setups": [{"pattern":"queue-publish","direction":"publish","destinationQueue":"task-queue"}] }
      },
      "messages": [
        {
          "from": "sender",
          "routingKey": "task-queue",
          "payload": {"taskId":"qp-1","action":"process"},
          "expectedDeliveries": []
        }
      ]
    }
  ]
}
