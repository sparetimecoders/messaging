{
  "scenarios": [
    {
      "name": "event stream publish and consume",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-123","amount":42},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-123","amount":42}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.Outbound",
          "payload": {"probeId":"out-1"},
          "ceAttributes": {"type":"Probe.Outbound","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "notifications",
          "routingKey": "Order.Created",
          "payload": {"probeId":"in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "event stream fan-out",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] },
        "analytics":     { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-456","amount":99},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-456"}},
            {"to":"analytics","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"amount":99}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.FanOut",
          "payload": {"probeId":"fanout-out-1"},
          "ceAttributes": {"type":"Probe.FanOut","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"fanout-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "notifications",
          "routingKey": "Order.Created",
          "payload": {"probeId":"fanout-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"fanout-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "custom stream publish and consume",
      "services": {
        "analytics": { "setups": [
          {"pattern":"custom-stream","direction":"publish","exchange":"audit"},
          {"pattern":"custom-stream","direction":"consume","exchange":"audit","routingKey":"Audit.Entry"}
        ]}
      },
      "messages": [
        {
          "from": "analytics",
          "routingKey": "Audit.Entry",
          "payload": {"action":"login","userId":"user-456"},
          "expectedDeliveries": [
            {"to":"analytics","metadata":{"type":"Audit.Entry","source":"analytics","specVersion":"1.0"},"payloadMatch":{"action":"login","userId":"user-456"}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "analytics",
          "routingKey": "Probe.AuditOut",
          "payload": {"probeId":"audit-out-1"},
          "ceAttributes": {"type":"Probe.AuditOut","source":"analytics","specversion":"1.0"},
          "payloadMatch": {"probeId":"audit-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "analytics",
          "routingKey": "Audit.Entry",
          "payload": {"probeId":"audit-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Audit.Entry","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"audit-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "transient consumer",
      "services": {
        "orders":    { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "dashboard": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created","ephemeral":true}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"test-789","amount":10},
          "expectedDeliveries": [
            {"to":"dashboard","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"test-789"}}
          ]
        }
      ],
      "probeMessages": [
        {
          "direction": "outbound",
          "publishVia": "orders",
          "routingKey": "Probe.Transient",
          "payload": {"probeId":"transient-out-1"},
          "ceAttributes": {"type":"Probe.Transient","source":"orders","specversion":"1.0"},
          "payloadMatch": {"probeId":"transient-out-1"}
        },
        {
          "direction": "inbound",
          "expectReceivedBy": "dashboard",
          "routingKey": "Order.Created",
          "payload": {"probeId":"transient-in-1","_tckInjected":true},
          "ceAttributes": {"type":"Order.Created","source":"tck-probe","specversion":"1.0","datacontenttype":"application/json"},
          "payloadMatch": {"probeId":"transient-in-1","_tckInjected":true}
        }
      ]
    },
    {
      "name": "service request topology",
      "services": {
        "email-svc": { "setups": [
          {"pattern":"service-request","direction":"consume","routingKey":"email.send"}
        ]},
        "web-app": { "setups": [
          {"pattern":"service-request","direction":"publish","targetService":"email-svc"},
          {"pattern":"service-response","direction":"consume","targetService":"email-svc","routingKey":"email.send"}
        ]}
      },
      "messages": [
        {
          "from": "web-app",
          "routingKey": "email.send",
          "payload": {"to":"user@example.com","subject":"Welcome","body":"Hello!"},
          "expectedDeliveries": [
            {"to":"email-svc","metadata":{"type":"email.send","source":"web-app","specVersion":"1.0"},"payloadMatch":{"to":"user@example.com","subject":"Welcome"}}
          ]
        }
      ]
    },
    {
      "name": "wildcard routing",
      "services": {
        "orders":        { "setups": [{"pattern":"event-stream","direction":"publish"}] },
        "notifications": { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.*"}] },
        "billing":       { "setups": [{"pattern":"event-stream","direction":"consume","routingKey":"Order.Created"}] }
      },
      "messages": [
        {
          "from": "orders",
          "routingKey": "Order.Created",
          "payload": {"orderId":"wc-1","amount":50},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"wc-1"}},
            {"to":"billing","metadata":{"type":"Order.Created","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"wc-1"}}
          ]
        },
        {
          "from": "orders",
          "routingKey": "Order.Updated",
          "payload": {"orderId":"wc-2","status":"shipped"},
          "expectedDeliveries": [
            {"to":"notifications","metadata":{"type":"Order.Updated","source":"orders","specVersion":"1.0"},"payloadMatch":{"orderId":"wc-2"}}
          ],
          "unexpectedDeliveries": [
            {"to":"billing","metadataType":"Order.Updated"}
          ]
        }
      ]
    }
  ]
}
